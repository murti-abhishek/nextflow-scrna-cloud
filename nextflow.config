// nextflow.config — base configuration

params {
    outdir     = "s3://nextflow-scrna-abhishek/results"
    tmpdir     = "s3://nextflow-scrna-abhishek/tmp"
    input      = "data/samplesheet.csv"
}

profiles {
    local {
        process.executor = 'local'
        docker.enabled   = true
    }

    aws {
        process.executor        = 'awsbatch'
        process.queue           = 'nextflow-batch-queue'   // we'll create this shortly
        aws.region              = 'us-east-1'
        aws.batch.cliPath       = '/usr/local/bin/aws'
        workDir                 = 's3://nextflow-scrna-abhishek/work'
        docker.enabled          = true
    }
}

docker {
    enabled    = true
}